# Example .env — copy to .env and fill in your provider.
# Full reference in README.md → "Configure (.env)".

# --- Database ---
DATABASE_URL=postgresql://proxy:proxy@localhost:5432/memory_proxy

# --- Upstream LLM provider (OpenAI-compatible) ---
# OpenAI
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-...
# --- OR Nous Research (OAuth mode, leave UPSTREAM_API_KEY empty) ---
# UPSTREAM_BASE_URL=https://inference-api.nousresearch.com/v1
# NOUS_AUTH_FILE=/root/.hermes/nous_oauth.json
# --- OR a local model (Ollama / vLLM / LM Studio) ---
# UPSTREAM_BASE_URL=http://127.0.0.1:11434/v1
# UPSTREAM_API_KEY=not-needed

# --- Server ---
BIND_HOST=127.0.0.1
BIND_PORT=8899
AUTH_TOKEN=                      # set if BIND_HOST is non-loopback
RATE_LIMIT_PER_MIN=0

# --- Provider selection ---
PROVIDER_TYPE=openai             # openai | anthropic

# --- Embedding (multilingual, default) ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# --- Context budget ---
CONTEXT_WINDOW=8192
RESERVED_PCT=0.25

# --- Identity / single-user ---
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
SINGLE_USER_MODE=true            # true = one brain; false = per-user isolation

# --- Fact extraction (optional) ---
EXTRACTION_ENABLED=false
EXTRACTION_MODEL=                # model for extraction/consolidation (defaults to upstream)
