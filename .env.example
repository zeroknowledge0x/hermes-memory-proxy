# Memory Proxy — environment config (copy to .env and fill)

# --- Database ---
DATABASE_URL=postgresql://proxy:proxy@localhost:5432/memory_proxy

# --- Upstream LLM provider (OpenAI-compatible) ---
# The real provider the proxy forwards to.
UPSTREAM_BASE_URL=https://inference-api.nousresearch.com/v1
UPSTREAM_API_KEY=sk-changeme

# --- Server ---
BIND_HOST=127.0.0.1
BIND_PORT=8000
# Auth: required ONLY when BIND_HOST is non-loopback. Leave empty for local use.
AUTH_TOKEN=
# Rate limit: max requests per IP per minute (0 = off)
RATE_LIMIT_PER_MIN=0

# --- Provider selection (model-agnostic) ---
# openai = OpenAI/Nous/Gemini/Ollama/vLLM/LM Studio (OpenAI-compatible)
# anthropic = Anthropic Messages API
PROVIDER_TYPE=openai

# --- Embedding (multilingual, supports Bahasa Indonesia — D-014) ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# --- Context budget ---
CONTEXT_WINDOW=8192
RESERVED_PCT=0.25

# Identity
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
# Single-user mode (default ON): ignore payload `user` and always use DEFAULT_USER_ID.
# Turn OFF only when you truly need multi-tenant isolation.
SINGLE_USER_MODE=true

# --- Fact extraction (optional, Phase 1.5) ---
EXTRACTION_ENABLED=false
