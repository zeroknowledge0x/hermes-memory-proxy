# Copy to .env and fill in. ALL values are examples.

# --- Database ---
DATABASE_URL=postgresql://proxy:proxy@localhost:5432/memory_proxy

# --- Upstream LLM provider (the REAL one the proxy forwards to) ---
# MUST include /v1 for OpenAI-compatible bases.
PROVIDER_TYPE=openai
UPSTREAM_BASE_URL=https://inference-api.nousresearch.com/v1
# API-key mode:
UPSTREAM_API_KEY=
# OR OAuth mode (Nous):
NOUS_AUTH_FILE=

# --- Embedding (local, multilingual) ---
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384

# --- Memory extraction / consolidation ---
EXTRACTION_ENABLED=true
EXTRACTION_MODEL=tencent/hy3:free

# --- Proxy server ---
BIND_HOST=127.0.0.1
PORT=8899

# --- Security ---
AUTH_TOKEN=
RATE_LIMIT_PER_MIN=60

# --- Context budget ---
CONTEXT_WINDOW=120000
RESERVED_PCT=0.5
